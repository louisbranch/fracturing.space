# Minimal remote deployment contract for docker-compose.production.yml.
# Generate local secrets into .env.production with:
#   make prod-env

# Published image tag to deploy.
FRACTURING_SPACE_IMAGE_TAG=REPLACE_WITH_RELEASE_TAG

# Public DNS root for the deployment.
FRACTURING_SPACE_DOMAIN=example.com

# Optional ACME contact line for Caddy. Example:
# FRACTURING_SPACE_CADDY_EMAIL=email ops@example.com
FRACTURING_SPACE_CADDY_EMAIL=

# Remote Daggerheart reference corpus image. The image must expose the corpus at
# /reference-src with index.json at the root, and it must provide `sh` plus `cp`
# because the seed step copies the corpus into a named volume at container
# startup.
FRACTURING_SPACE_DAGGERHEART_REFERENCE_IMAGE=REPLACE_WITH_REFERENCE_IMAGE

# Game event integrity.
FRACTURING_SPACE_GAME_EVENT_HMAC_KEY=
FRACTURING_SPACE_GAME_EVENT_HMAC_KEYS=
FRACTURING_SPACE_GAME_EVENT_HMAC_KEY_ID=v1

# Join grant signing and verification.
FRACTURING_SPACE_JOIN_GRANT_ISSUER=fracturing.space/auth
FRACTURING_SPACE_JOIN_GRANT_AUDIENCE=fracturing.space/game
FRACTURING_SPACE_JOIN_GRANT_PUBLIC_KEY=
FRACTURING_SPACE_JOIN_GRANT_PRIVATE_KEY=
FRACTURING_SPACE_JOIN_GRANT_TTL=5m

# Play launch grant signing and verification.
FRACTURING_SPACE_PLAY_LAUNCH_GRANT_ISSUER=fracturing-space-web
FRACTURING_SPACE_PLAY_LAUNCH_GRANT_AUDIENCE=fracturing-space-play
FRACTURING_SPACE_PLAY_LAUNCH_GRANT_HMAC_KEY=
FRACTURING_SPACE_PLAY_LAUNCH_GRANT_TTL=2m

# OAuth resource introspection secret used by auth and admin.
FRACTURING_SPACE_OAUTH_RESOURCE_SECRET=
FRACTURING_SPACE_OAUTH_CLIENTS=

# AI service secrets.
FRACTURING_SPACE_AI_ENCRYPTION_KEY=
FRACTURING_SPACE_AI_SESSION_GRANT_HMAC_KEY=

# Protected Jaeger edge route. This env is interpolated directly into the Caddy
# site block, so it must be a full Caddy directive. Example:
# FRACTURING_SPACE_JAEGER_BASIC_AUTH=basic_auth { ops $2a$14$replace-with-caddy-hash }
FRACTURING_SPACE_JAEGER_BASIC_AUTH=

# OpenViking sidecar OpenAI API key.
FRACTURING_SPACE_OPENVIKING_OPENAI_API_KEY=

# Optional service tuning overrides.
FRACTURING_SPACE_WEB_DIAL_TIMEOUT=2s
FRACTURING_SPACE_USERHUB_DIAL_TIMEOUT=2s
FRACTURING_SPACE_USERHUB_CACHE_FRESH_TTL=15s
FRACTURING_SPACE_USERHUB_CACHE_STALE_TTL=2m
FRACTURING_SPACE_WORKER_CONSUMER=worker-onboarding
FRACTURING_SPACE_WORKER_POLL_INTERVAL=2s
FRACTURING_SPACE_WORKER_LEASE_TTL=30s
FRACTURING_SPACE_WORKER_MAX_ATTEMPTS=8
FRACTURING_SPACE_WORKER_RETRY_BACKOFF=5s
FRACTURING_SPACE_WORKER_RETRY_MAX_DELAY=5m
FRACTURING_SPACE_NOTIFICATIONS_EMAIL_DELIVERY_ENABLED=
FRACTURING_SPACE_NOTIFICATIONS_EMAIL_DELIVERY_WORKER_ENABLED=
FRACTURING_SPACE_NOTIFICATIONS_EMAIL_DELIVERY_WORKER_POLL_INTERVAL=5s
FRACTURING_SPACE_ASSET_BASE_URL=https://res.cloudinary.com/fracturing-space/image/upload
FRACTURING_SPACE_ASSET_VERSION=v1
