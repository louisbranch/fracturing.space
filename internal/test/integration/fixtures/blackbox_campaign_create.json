{
  "name": "mcp_http_blackbox_campaign_create",
  "steps": [
    {
      "name": "initialize",
      "action": "initialize"
    },
    {
      "name": "initialized",
      "action": "initialized"
    },
    {
      "name": "campaign_create",
      "action": "tool_call",
      "tool": "campaign_create",
      "args": {
        "name": "Scenario Campaign",
        "system": "DAGGERHEART",
        "gm_mode": "HUMAN",
        "theme_prompt": "short flow"
      },
      "capture": {
        "campaign_id": "campaign",
        "owner_id": "result.structuredContent.owner_participant_id"
      }
    },
    {
      "name": "set_context_owner",
      "action": "tool_call",
      "tool": "set_context",
      "args": {
        "campaign_id": {"ref": "campaign_id"},
        "participant_id": {"ref": "owner_id"}
      },
      "expect": "none"
    },
    {
      "name": "campaign_read",
      "action": "read_resource",
      "uri": "campaign://{{campaign_id}}",
      "expect_paths": {
        "result.contents[0].text|json.campaign.id": "{{campaign_id}}",
        "result.contents[0].text|json.campaign.name": "Scenario Campaign"
      }
    }
  ]
}
